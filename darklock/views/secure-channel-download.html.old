    <!-- Auto-detect platform & highlight -->
    <script>
    (function() {
        var ua = navigator.userAgent.toLowerCase();
        var p = null;
        if (/iphone|ipad|ipod/.test(ua)) p = 'ios';
        else if (/android/.test(ua)) p = 'android';
        else if (/macintosh|mac os/.test(ua)) p = 'macos';
        else if (/win/.test(ua)) p = 'windows';
        else if (/linux/.test(ua)) p = 'linux';
        if (!p) return;
        var cards = document.querySelectorAll('.card[data-platform]');
        for (var i = 0; i < cards.length; i++) {
            if (cards[i].getAttribute('data-platform') === p) {
                cards[i].classList.add('highlight');
                // Move to first position
                cards[i].parentNode.insertBefore(cards[i], cards[i].parentNode.firstChild);
                break;
            }
        }
    })();
    </script>
</body>
