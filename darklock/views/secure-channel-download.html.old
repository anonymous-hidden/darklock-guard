<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Download Darklock Secure Channel</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: radial-gradient(ellipse at 18% 12%, rgba(124,77,255,0.10), transparent 38%),
                        radial-gradient(ellipse at 82% 8%, rgba(0,212,255,0.07), transparent 32%),
                        radial-gradient(ellipse at 50% 95%, rgba(124,77,255,0.06), transparent 40%),
                        #0a0e1a;
            min-height: 100vh;
            display: flex; flex-direction: column; align-items: center;
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            color: #e8ecf4;
            padding: 40px 16px 60px;
            -webkit-font-smoothing: antialiased;
        }

        /* ── Header ── */
        .hero { text-align: center; margin-bottom: 48px; max-width: 640px; }
        .shield-icon {
            width: 88px; height: 88px; margin-bottom: 18px;
            filter: drop-shadow(0 0 28px rgba(124,77,255,0.5));
        }
        h1 {
            font-size: clamp(28px, 5vw, 42px); font-weight: 800; line-height: 1.1;
            background: linear-gradient(135deg, #a78bfa 0%, #7c4dff 35%, #00d4ff 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            background-clip: text; margin-bottom: 10px;
        }
        .subtitle { color: #94a3b8; font-size: 16px; line-height: 1.6; }
        .version-row {
            display: flex; align-items: center; justify-content: center;
            gap: 10px; margin-top: 16px; flex-wrap: wrap;
        }
        .version-pill {
            display: inline-flex; align-items: center; gap: 6px;
            background: rgba(124,77,255,0.15); border: 1px solid rgba(124,77,255,0.3);
            border-radius: 20px; padding: 5px 14px; font-size: 13px;
            color: #a78bfa; font-weight: 600;
        }
        .version-pill .dot { width: 7px; height: 7px; border-radius: 50%; background: #22c55e; animation: pulse 2s infinite; }
        @keyframes pulse { 0%,100%{ opacity:1; } 50%{ opacity:.4; } }
        .e2e-badge {
            display: inline-flex; align-items: center; gap: 6px;
            background: rgba(0,212,255,0.10); border: 1px solid rgba(0,212,255,0.25);
            border-radius: 20px; padding: 5px 14px; font-size: 12px;
            color: #67e8f9; font-weight: 600;
        }

        /* ── Grid ── */
        .platforms {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
            gap: 20px; width: min(960px, 100%);
        }

        /* ── Card ── */
        .card {
            background: linear-gradient(168deg, rgba(17,24,42,0.92), rgba(10,14,28,0.97));
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 16px; padding: 32px 26px 28px;
            display: flex; flex-direction: column; align-items: center;
            transition: border-color .3s, box-shadow .3s, transform .3s;
            position: relative; overflow: hidden;
        }
        .card::before {
            content: ''; position: absolute; inset: 0;
            background: radial-gradient(circle at 50% -20%, var(--glow, rgba(124,77,255,0.05)), transparent 65%);
            pointer-events: none;
        }
        .card:hover {
            border-color: rgba(124,77,255,0.4);
            box-shadow: 0 14px 52px rgba(124,77,255,0.10);
            transform: translateY(-4px);
        }
        .card.highlight {
            border-color: rgba(124,77,255,0.45);
            box-shadow: 0 0 40px rgba(124,77,255,0.10);
        }
        .rec-badge {
            position: absolute; top: 12px; right: 12px;
            background: linear-gradient(135deg, #7c4dff, #00d4ff);
            color: #fff; font-size: 10px; font-weight: 700;
            padding: 3px 10px; border-radius: 8px; letter-spacing: 0.3px;
            display: none;
        }
        .card.highlight .rec-badge { display: block; }

        .card-icon {
            width: 56px; height: 56px; margin-bottom: 16px;
            display: flex; align-items: center; justify-content: center;
            border-radius: 14px; font-size: 28px;
        }
        .card-icon.windows { background: rgba(0,120,215,0.12); color: #47b5ff; --glow: rgba(0,120,215,0.06); }
        .card-icon.linux    { background: rgba(255,170,0,0.10); color: #ffaa00; --glow: rgba(255,170,0,0.05); }
        .card-icon.macos    { background: rgba(255,255,255,0.06); color: #d4d4d8; --glow: rgba(255,255,255,0.04); }
        .card-icon.ios      { background: rgba(0,212,255,0.10); color: #00d4ff; --glow: rgba(0,212,255,0.05); }
        .card-icon.android  { background: rgba(61,220,132,0.10); color: #3ddc84; --glow: rgba(61,220,132,0.05); }

        .card h3 { font-size: 19px; font-weight: 700; margin-bottom: 4px; color: #f1f5f9; }
        .card .arch { font-size: 12px; color: #64748b; margin-bottom: 20px; }

        .dl-btn {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 11px 24px; border-radius: 10px; font-size: 14px;
            font-weight: 600; text-decoration: none; transition: all .2s;
            cursor: pointer; border: none; width: 100%;
            justify-content: center; position: relative;
        }
        .dl-btn svg { width: 16px; height: 16px; fill: currentColor; flex-shrink: 0; }
        .dl-btn.primary {
            background: linear-gradient(135deg, #7c4dff, #6535e0);
            color: #fff; box-shadow: 0 4px 20px rgba(124,77,255,0.25);
        }
        .dl-btn.primary:hover { background: linear-gradient(135deg, #9168ff, #7c4dff); box-shadow: 0 6px 28px rgba(124,77,255,0.35); }
        .dl-btn.secondary {
            background: rgba(124,77,255,0.06); border: 1px solid rgba(124,77,255,0.22);
            color: #a78bfa; margin-top: 10px;
        }
        .dl-btn.secondary:hover { background: rgba(124,77,255,0.14); }
        .dl-btn.coming-soon {
            background: rgba(100,116,139,0.08); border: 1px solid rgba(100,116,139,0.18);
            color: #525f75; cursor: default; pointer-events: none;
        }
        .file-meta { font-size: 11px; color: #475569; margin-top: 10px; line-height: 1.5; }

        /* ── Features ── */
        .features {
            display: flex; flex-wrap: wrap; justify-content: center;
            gap: 10px; margin-top: 48px; width: min(960px, 100%);
        }
        .feat {
            display: flex; align-items: center; gap: 8px;
            background: rgba(17,24,42,0.6); border: 1px solid rgba(124,77,255,0.10);
            border-radius: 10px; padding: 9px 16px; font-size: 13px; color: #94a3b8;
        }
        .feat-dot { width: 7px; height: 7px; border-radius: 50%; background: linear-gradient(135deg, #7c4dff, #00d4ff); flex-shrink: 0; }

        /* ── System requirements ── */
        .sysreq {
            margin-top: 40px; width: min(960px, 100%);
            display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 14px;
        }
        .sysreq-item {
            background: rgba(17,24,42,0.5); border: 1px solid rgba(255,255,255,0.04);
            border-radius: 10px; padding: 16px 18px;
        }
        .sysreq-item strong {
            display: block; font-size: 11px; font-weight: 700;
            color: #7c4dff; text-transform: uppercase;
            letter-spacing: 0.5px; margin-bottom: 6px;
        }
        .sysreq-item span { font-size: 12px; color: #64748b; line-height: 1.6; display: block; }

        /* ── Footer ── */
        footer {
            margin-top: 56px; text-align: center; color: #3f4a5c;
            font-size: 12px; line-height: 2;
        }
        footer a { color: #7c4dff; text-decoration: none; }
        footer a:hover { text-decoration: underline; }

        @media (max-width: 640px) {
            .platforms { grid-template-columns: 1fr; }
            .sysreq { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
