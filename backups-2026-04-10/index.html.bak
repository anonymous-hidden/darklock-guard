                        <div class="site-hero-stat-val" id="statServers">—</div>
                        <div class="site-hero-stat-lbl">Servers</div>
                    </div>
                    <div class="site-hero-stat">
                        <div class="site-hero-stat-val" id="statUsers">—</div>
                        <div class="site-hero-stat-lbl">Users Protected</div>
                    </div>
