                                <div class="site-mock-bar" style="height:65%"></div>
                                <div class="site-mock-bar" style="height:35%"></div>
                                <div class="site-mock-bar" style="height:80%"></div>
                                <div class="site-mock-bar" style="height:55%"></div>
                                <div class="site-mock-bar" style="height:45%"></div>
