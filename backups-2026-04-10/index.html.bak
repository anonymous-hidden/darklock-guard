<script src="js/main.js?v=4"></script>
<script src="js/global-theme.js"></script>
<script>
(function() {
    'use strict';

    // Nav scroll
    var nav = document.getElementById('siteNav');
    window.addEventListener('scroll', function() {
        nav.classList.toggle('scrolled', window.scrollY > 40);
    });

    // Smooth reveal
    var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.site-reveal').forEach(function(el) { observer.observe(el); });

    // Card spotlight effect
    document.querySelectorAll('.site-feat-card, .site-price-card').forEach(function(card) {
        card.addEventListener('mousemove', function(e) {
            var rect = card.getBoundingClientRect();
            card.style.setProperty('--mx', (e.clientX - rect.left) + 'px');
            card.style.setProperty('--my', (e.clientY - rect.top) + 'px');
        });
    });

    // Fetch live stats
    function loadStats() {
        fetch('/api/stats').then(function(r) { return r.json(); }).then(function(d) {
            if (d.servers) {
                document.getElementById('serverCount').textContent = d.servers;
                document.getElementById('statServers').textContent = d.servers;
            }
            if (d.users) document.getElementById('statUsers').textContent = formatNum(d.users);
            if (d.uptime) document.getElementById('statUptime').textContent = d.uptime;
        }).catch(function() {});
    }
    function formatNum(n) {
        if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
        if (n >= 1000) return (n / 1000).toFixed(1) + 'K';
        return n.toString();
    }
    loadStats();
    setInterval(loadStats, 60000);

    // Invite link
    var inviteUrl = 'https://discord.com/api/oauth2/authorize?client_id=1439793800309379114&permissions=8&scope=bot%20applications.commands';
    var inviteBtns = ['inviteBtn', 'heroInvite', 'priceFreeBtn', 'ctaInvite', 'footerInvite'];
    inviteBtns.forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('click', function(e) { e.preventDefault(); window.open(inviteUrl, '_blank'); });
    });

    // Pro pricing button — coming soon notice
    var priceProBtn = document.getElementById('priceProBtn');
    if (priceProBtn) {
        priceProBtn.addEventListener('click', function(e) {
            e.preventDefault();
            alert('Pro plan is coming soon! For now, all features are free.');
        });
    }

    // Mobile toggle
    var toggle = document.getElementById('siteNavToggle');
    var links = document.getElementById('siteNavLinks');
    if (toggle) {
        toggle.addEventListener('click', function() {
            var shown = links.style.display === 'flex';
            links.style.display = shown ? '' : 'flex';
            links.style.flexDirection = shown ? '' : 'column';
            links.style.position = shown ? '' : 'absolute';
            links.style.top = shown ? '' : '100%';
            links.style.left = shown ? '' : '0';
            links.style.right = shown ? '' : '0';
            links.style.background = shown ? '' : 'rgba(6,6,11,0.96)';
            links.style.padding = shown ? '' : '1rem 1.5rem';
            links.style.gap = shown ? '' : '0.75rem';
            links.style.borderBottom = shown ? '' : '1px solid rgba(255,255,255,0.06)';
        });
    }
})();
</script>

</body>
</html>
