# Home AI Assistant - Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control

# Ollama runs locally — no API key needed.
# Make sure `ollama serve` is running before starting Home AI.
# The model used is configured in config.yaml (default: llama3.2:3b)

# API Server Authentication Key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
HOME_AI_API_KEY=generate-a-secure-key-here

# Remote Backup Server Key
HOME_AI_BACKUP_KEY=your-backup-server-key-here

# National Weather Service API — free, no key needed, but User-Agent is required.
# Format: (AppName, contact@email.com)
# NWS uses this to contact you if your app exhibits unusual behavior.
NWS_USER_AGENT=(HomeAI, anonymous-hide-me-pls@proton.me)

# Optional: NWS is testing a traditional API key on some endpoints.
# Leave blank — the API is still fully open without it.
NWS_API_KEY=

# Optional: Override config file location
# HOME_AI_CONFIG=/path/to/config.yaml
