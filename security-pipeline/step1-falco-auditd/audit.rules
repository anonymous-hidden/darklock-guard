# =============================================================================
# Custom auditd Rules — Security Pipeline
# Monitors: auth events, sudo, permission changes, cron mods, SUID binaries
# Install: cp audit.rules /etc/audit/rules.d/99-security-pipeline.rules
#          augenrules --load
# =============================================================================

# Clear existing rules (start fresh)
-D

# Set buffer size (increase for busy systems)
-b 8192

# Set failure mode: 1=printk, 2=panic
-f 1

# Rate limit: max 100 messages/sec to avoid flooding
-r 100

# =============================================================================
# SECTION 1: Authentication events — all login/logout/failures
# =============================================================================

# Monitor all authentication attempts (PAM)
-w /etc/pam.d/ -p wa -k auth_pam_changes

# Watch login-related files
-w /var/log/auth.log -p r -k auth_log_access
-w /var/log/faillog -p wa -k auth_faillog
-w /var/log/lastlog -p wa -k auth_lastlog
-w /var/log/wtmp -p wa -k auth_wtmp
-w /var/log/btmp -p wa -k auth_btmp

# Monitor user/group databases
-w /etc/passwd -p wa -k auth_user_modification
-w /etc/shadow -p wa -k auth_shadow_modification
-w /etc/group -p wa -k auth_group_modification
-w /etc/gshadow -p wa -k auth_gshadow_modification

# SSH configuration changes
-w /etc/ssh/sshd_config -p wa -k auth_sshd_config
-w /etc/ssh/ssh_config -p wa -k auth_ssh_config
-w /etc/ssh/ -p wa -k auth_ssh_dir

# SSH authorized keys (all users)
-w /home/ -p wa -k auth_authorized_keys
# Root authorized keys
-w /root/.ssh/ -p wa -k auth_root_ssh

# Login programs
-w /bin/login -p x -k auth_login
-w /bin/su -p x -k auth_su

# =============================================================================
# SECTION 2: Sudo usage — every invocation, success or failure
# =============================================================================

# Watch sudo binary execution
-w /usr/bin/sudo -p x -k sudo_usage

# Watch sudoers files for modifications
-w /etc/sudoers -p wa -k sudo_config_change
-w /etc/sudoers.d/ -p wa -k sudo_config_change

# Capture all sudo commands with arguments
-a always,exit -F arch=b64 -S execve -F euid=0 -F auid>=1000 -F auid!=4294967295 -k sudo_command
-a always,exit -F arch=b32 -S execve -F euid=0 -F auid>=1000 -F auid!=4294967295 -k sudo_command

# pkexec (polkit privilege escalation)
-w /usr/bin/pkexec -p x -k pkexec_usage

# =============================================================================
# SECTION 3: File permission changes — chmod, chown, setxattr
# =============================================================================

# chmod/chown syscalls (64-bit)
-a always,exit -F arch=b64 -S chmod -S fchmod -S fchmodat -k perm_change
-a always,exit -F arch=b64 -S chown -S fchown -S fchownat -S lchown -k owner_change

# chmod/chown syscalls (32-bit compat)
-a always,exit -F arch=b32 -S chmod -S fchmod -S fchmodat -k perm_change
-a always,exit -F arch=b32 -S chown -S fchown -S fchownat -S lchown -k owner_change

# Extended attribute changes (used to set capabilities)
-a always,exit -F arch=b64 -S setxattr -S lsetxattr -S fsetxattr -k xattr_change
-a always,exit -F arch=b64 -S removexattr -S lremovexattr -S fremovexattr -k xattr_change

# =============================================================================
# SECTION 4: Cron modifications — all crontab changes
# =============================================================================

# System crontab
-w /etc/crontab -p wa -k cron_modification

# Cron directories
-w /etc/cron.d/ -p wa -k cron_modification
-w /etc/cron.daily/ -p wa -k cron_modification
-w /etc/cron.hourly/ -p wa -k cron_modification
-w /etc/cron.weekly/ -p wa -k cron_modification
-w /etc/cron.monthly/ -p wa -k cron_modification

# User crontabs
-w /var/spool/cron/ -p wa -k cron_user_modification

# AT jobs
-w /var/spool/at/ -p wa -k at_modification
-w /etc/at.allow -p wa -k at_access_control
-w /etc/at.deny -p wa -k at_access_control
-w /etc/cron.allow -p wa -k cron_access_control
-w /etc/cron.deny -p wa -k cron_access_control

# Systemd timers (modern cron replacement)
-w /etc/systemd/system/ -p wa -k systemd_timer_modification

# =============================================================================
# SECTION 5: New SUID/SGID binaries — privilege escalation persistence
# =============================================================================

# Detect chmod calls that set SUID bit (04000) or SGID bit (02000)
-a always,exit -F arch=b64 -S chmod -S fchmod -S fchmodat -F a1&0x6000 -k suid_sgid_creation
-a always,exit -F arch=b32 -S chmod -S fchmod -S fchmodat -F a1&0x6000 -k suid_sgid_creation

# Watch common SUID binary locations
-w /usr/bin/ -p wa -k suid_binary_write
-w /usr/sbin/ -p wa -k suid_binary_write
-w /usr/local/bin/ -p wa -k suid_binary_write
-w /usr/local/sbin/ -p wa -k suid_binary_write

# =============================================================================
# SECTION 6: Additional security events
# =============================================================================

# Kernel module loading (rootkit detection)
-w /sbin/insmod -p x -k kernel_module
-w /sbin/rmmod -p x -k kernel_module
-w /sbin/modprobe -p x -k kernel_module
-a always,exit -F arch=b64 -S init_module -S finit_module -S delete_module -k kernel_module

# Mount operations (container escape / persistence)
-a always,exit -F arch=b64 -S mount -S umount2 -k mount_operation

# Ptrace (process injection / debugging)
-a always,exit -F arch=b64 -S ptrace -k process_injection

# Executable memory mapping (exploit indicator)
-a always,exit -F arch=b64 -S mmap -F a2&0x4 -k executable_mmap

# Network socket creation (detect unexpected listeners)
-a always,exit -F arch=b64 -S socket -F a0=2 -k network_socket_ipv4
-a always,exit -F arch=b64 -S socket -F a0=10 -k network_socket_ipv6

# Time change (anti-forensics)
-a always,exit -F arch=b64 -S adjtimex -S settimeofday -S clock_settime -k time_change
-w /etc/localtime -p wa -k time_change

# Make rules immutable (requires reboot to change — prevents attacker from disabling)
# Uncomment in production after testing:
# -e 2
