{
  "manifest_version": 3,
  "name": "Nova Browser Bridge",
  "version": "1.0.0",
  "description": "Lets Nova read and control the active browser tab through the local Nova bridge.",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' ws://localhost:* ws://127.0.0.1:*"
  },
  "action": {
    "default_title": "Nova Browser Bridge",
    "default_popup": "popup.html"
  }
}
