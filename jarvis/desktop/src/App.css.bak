/* ═══════════════════════════════════════════════════════
   Nova — Desktop App Styles
   ═══════════════════════════════════════════════════════ */

:root {
  --bg:              #0a0a1a;
  --bg-sidebar:      #0f0f25;
  --bg-card:         #151530;
  --bg-input:        #12122a;
  --bg-hover:        #1a1a3a;
  --bg-active:       #1e1e45;
  --accent:          #00d4ff;
  --accent-dim:      rgba(0, 212, 255, 0.15);
  --text:            #e0e0f0;
  --text-secondary:  #8888aa;
  --text-muted:      #555570;
  --border:          #1a1a35;
  --danger:          #f38ba8;
  --success:         #a6e3a1;
  --warning:         #f9e2af;
  --radius:          10px;
  --radius-sm:       6px;
  --font:            'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --font-mono:       'Cascadia Code', 'Fira Code', 'JetBrains Mono', monospace;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html, body, #root { width: 100%; height: 100%; overflow: hidden; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--font);
  font-size: 14px;
  line-height: 1.55;
}

/* ── Layout ──────────────────────────────────────── */

.app {
  display: flex;
  width: 100%;
  height: 100%;
}

/* ── Sidebar ─────────────────────────────────────── */

.sidebar {
  width: 260px;
  min-width: 260px;
  background: var(--bg-sidebar);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  height: 100%;
}

.sidebar-header {
  padding: 16px 14px 10px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.sidebar-brand {
  font-size: 16px;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: 1px;
}

.sidebar-new {
  margin-left: auto;
  background: var(--accent-dim);
  border: 1px solid rgba(0, 212, 255, 0.25);
  color: var(--accent);
  border-radius: var(--radius-sm);
  padding: 5px 12px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.15s;
}
.sidebar-new:hover { background: rgba(0, 212, 255, 0.25); }

.sidebar-list {
  flex: 1;
  overflow-y: auto;
  padding: 6px 8px;
}

.sidebar-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 9px 10px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  color: var(--text-secondary);
  font-size: 13px;
  transition: background 0.12s, color 0.12s;
  position: relative;
}
.sidebar-item:hover { background: var(--bg-hover); color: var(--text); }
.sidebar-item.active { background: var(--bg-active); color: var(--text); }

.sidebar-item-title {
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sidebar-item-delete {
  opacity: 0;
  background: none;
  border: none;
  color: var(--danger);
  cursor: pointer;
  font-size: 14px;
  padding: 0 4px;
  transition: opacity 0.15s;
}
.sidebar-item:hover .sidebar-item-delete { opacity: 0.7; }
.sidebar-item-delete:hover { opacity: 1 !important; }

.sidebar-footer {
  padding: 10px 14px;
  border-top: 1px solid var(--border);
}

.sidebar-settings-btn {
  width: 100%;
  background: transparent;
  border: 1px solid var(--border);
  color: var(--text-secondary);
  border-radius: var(--radius-sm);
  padding: 8px;
  font-size: 12px;
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
}
.sidebar-settings-btn:hover { background: var(--bg-hover); color: var(--text); }

/* ── Main Area ───────────────────────────────────── */

.main {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: var(--bg);
  min-width: 0;
}

/* ── Chat Area ───────────────────────────────────── */

.chat-area {
  flex: 1;
  overflow-y: auto;
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

/* Welcome splash when no messages */
.chat-welcome {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  color: var(--text-muted);
}
.chat-welcome-icon {
  font-size: 48px;
  color: var(--accent);
  opacity: 0.5;
}
.chat-welcome h2 {
  color: var(--text-secondary);
  font-weight: 600;
  font-size: 20px;
}
.chat-welcome p {
  max-width: 400px;
  text-align: center;
  line-height: 1.6;
}

/* ── Message Bubble ──────────────────────────────── */

.message-row {
  display: flex;
  gap: 12px;
  padding: 14px 0;
  max-width: 800px;
  width: 100%;
  align-self: center;
}

.message-row.user { flex-direction: row-reverse; }

.message-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 700;
  flex-shrink: 0;
}
.message-row.assistant .message-avatar {
  background: var(--accent-dim);
  color: var(--accent);
  border: 1px solid rgba(0, 212, 255, 0.3);
}
.message-row.user .message-avatar {
  background: rgba(148, 226, 213, 0.15);
  color: #94e2d5;
  border: 1px solid rgba(148, 226, 213, 0.3);
}

.message-bubble {
  padding: 10px 16px;
  border-radius: var(--radius);
  line-height: 1.6;
  max-width: 85%;
  word-break: break-word;
}
.message-row.assistant .message-bubble {
  background: var(--bg-card);
  border: 1px solid var(--border);
}
.message-row.user .message-bubble {
  background: rgba(0, 212, 255, 0.08);
  border: 1px solid rgba(0, 212, 255, 0.15);
}
.message-row.system .message-bubble {
  background: rgba(243, 139, 168, 0.08);
  border: 1px solid rgba(243, 139, 168, 0.15);
  color: var(--danger);
  font-size: 13px;
}

/* Markdown inside messages */
.message-bubble p { margin: 0 0 8px; }
.message-bubble p:last-child { margin: 0; }
.message-bubble code {
  background: rgba(255, 255, 255, 0.06);
  padding: 1px 5px;
  border-radius: 3px;
  font-family: var(--font-mono);
  font-size: 13px;
}
.message-bubble pre {
  background: #1e1e2e;
  border-radius: var(--radius-sm);
  padding: 12px 14px;
  overflow-x: auto;
  margin: 8px 0;
  border: 1px solid rgba(255, 255, 255, 0.04);
}
.message-bubble pre code {
  background: none;
  padding: 0;
  font-size: 13px;
  color: #cdd6f4;
}
.message-bubble ul, .message-bubble ol {
  padding-left: 20px;
  margin: 6px 0;
}
.message-bubble blockquote {
  border-left: 3px solid var(--accent);
  padding-left: 12px;
  color: var(--text-secondary);
  margin: 8px 0;
}

/* Streaming cursor */
.streaming-cursor {
  display: inline-block;
  width: 2px;
  height: 16px;
  background: var(--accent);
  margin-left: 2px;
  animation: blink 0.8s infinite;
  vertical-align: text-bottom;
}
@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

/* ── Proactive Messages (Nova-initiated) ─────────── */

.message-row.proactive .message-bubble {
  border-left: 3px solid var(--accent);
  background: linear-gradient(135deg, rgba(137,180,250,0.08), rgba(137,180,250,0.02));
}
.message-row.proactive-alert .message-bubble {
  border-left: 3px solid #f38ba8;
  background: linear-gradient(135deg, rgba(243,139,168,0.1), rgba(243,139,168,0.02));
}
.message-row.proactive .message-avatar {
  font-size: 16px;
  line-height: 30px;
}
.proactive-label {
  display: block;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--accent);
  margin-bottom: 4px;
  font-weight: 600;
}
.proactive-alert .proactive-label {
  color: #f38ba8;
}

/* ── Input Bar ───────────────────────────────────── */

.input-bar {
  padding: 12px 20px 20px;
  display: flex;
  justify-content: center;
}

.input-bar-inner {
  display: flex;
  align-items: flex-end;
  gap: 10px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 10px 14px;
  width: 100%;
  max-width: 800px;
  transition: border-color 0.2s;
}
.input-bar-inner:focus-within { border-color: var(--accent); }

.input-textarea {
  flex: 1;
  background: none;
  border: none;
  outline: none;
  color: var(--text);
  font-family: var(--font);
  font-size: 14px;
  line-height: 1.5;
  resize: none;
  max-height: 150px;
  min-height: 22px;
}
.input-textarea::placeholder { color: var(--text-muted); }

.input-send {
  background: var(--accent);
  border: none;
  border-radius: 10px;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #0a0a1a;
  font-size: 16px;
  font-weight: 700;
  transition: opacity 0.15s;
  flex-shrink: 0;
}
.input-send:disabled { opacity: 0.3; cursor: not-allowed; }
.input-send:not(:disabled):hover { opacity: 0.85; }

.input-voice {
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 10px;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--text-secondary);
  font-size: 16px;
  transition: background 0.15s, color 0.15s;
  flex-shrink: 0;
}
.input-voice:hover { background: var(--bg-hover); color: var(--accent); }
.input-voice.active {
  background: rgba(243, 139, 168, 0.15);
  border-color: rgba(243, 139, 168, 0.3);
  color: var(--danger);
  animation: pulse 1.5s infinite;
}
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.08); } }

/* ── Settings Panel ──────────────────────────────── */

.settings-panel {
  flex: 1;
  padding: 40px 30px;
  overflow-y: auto;
  max-width: 600px;
  margin: 0 auto;
}
.settings-panel h2 {
  font-size: 22px;
  font-weight: 700;
  color: var(--accent);
  margin-bottom: 24px;
}
.settings-group {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 18px 20px;
  margin-bottom: 16px;
}
.settings-group h3 {
  font-size: 13px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text-secondary);
  margin-bottom: 12px;
}
.settings-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
}
.settings-label { color: var(--text); font-size: 14px; }
.settings-value { color: var(--accent); font-family: var(--font-mono); font-size: 13px; }
.settings-close {
  background: var(--accent-dim);
  border: 1px solid rgba(0, 212, 255, 0.25);
  color: var(--accent);
  border-radius: var(--radius-sm);
  padding: 8px 20px;
  font-size: 13px;
  cursor: pointer;
  margin-top: 20px;
}

/* ── Scrollbar ───────────────────────────────────── */

::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--text-muted); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--text-secondary); }

/* ── Mood Indicator (single emoji + hover) ─────── */

.mood-indicator {
  position: relative;
  display: inline-flex;
  align-items: center;
  cursor: default;
  margin-left: 8px;
}
.mood-emoji {
  font-size: 22px;
  line-height: 1;
  transition: transform 0.3s;
  filter: drop-shadow(0 0 4px rgba(0, 212, 255, 0.3));
}
.mood-indicator:hover .mood-emoji { transform: scale(1.3); }

.mood-tooltip {
  display: none;
  position: absolute;
  top: calc(100% + 10px);
  left: 50%;
  transform: translateX(-50%);
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 14px 18px;
  min-width: 220px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  z-index: 100;
}
.mood-indicator:hover .mood-tooltip { display: block; }

.mood-tooltip-title {
  font-size: 13px;
  color: var(--text);
  margin-bottom: 10px;
  text-align: center;
}
.mood-tooltip-bars {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.mood-tooltip-row {
  display: flex;
  align-items: center;
  gap: 8px;
}
.mood-tooltip-label {
  width: 80px;
  font-size: 11px;
  color: var(--text-secondary);
  text-transform: capitalize;
}
.mood-tooltip-track {
  flex: 1;
  height: 5px;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 3px;
  overflow: hidden;
}
.mood-tooltip-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.6s ease;
}
.mood-tooltip-val {
  width: 32px;
  font-size: 10px;
  color: var(--text-muted);
  text-align: right;
  font-family: var(--font-mono);
}

/* ── Image in messages ───────────────────────────── */

.message-image {
  max-width: 300px;
  max-height: 300px;
  border-radius: var(--radius-sm);
  margin: 8px 0;
  border: 1px solid var(--border);
  cursor: pointer;
  transition: transform 0.2s;
}
.message-image:hover { transform: scale(1.02); }

.image-preview {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  margin-bottom: 4px;
}
.image-preview img {
  width: 40px;
  height: 40px;
  border-radius: 4px;
  object-fit: cover;
}
.image-preview-name {
  font-size: 12px;
  color: var(--text-secondary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.image-preview-remove {
  background: none;
  border: none;
  color: var(--danger);
  cursor: pointer;
  font-size: 14px;
  padding: 0 4px;
}

.input-attach {
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 10px;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--text-secondary);
  font-size: 16px;
  transition: background 0.15s, color 0.15s;
  flex-shrink: 0;
}
.input-attach:hover { background: var(--bg-hover); color: var(--accent); }

/* ── Voice Call — ChatGPT style ──────────────────── */

/* ═══ JARVIS-style Voice Call ═══ */
@keyframes vc-breathe {
  0%, 100% { transform: scale(1);    opacity: 0.35; }
  50%       { transform: scale(1.18); opacity: 0.65; }
}
@keyframes vc-ripple {
  0%   { transform: scale(0.9); opacity: 0.6; }
  100% { transform: scale(1.6); opacity: 0; }
}
@keyframes vc-spin-slow {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}
@keyframes vc-pulse-fast {
  0%, 100% { transform: scale(1);    box-shadow: 0 0 0 0 rgba(0,212,255,0.5); }
  50%       { transform: scale(1.04); box-shadow: 0 0 0 18px rgba(0,212,255,0); }
}
@keyframes vc-live-dot {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.3; }
}
@keyframes vc-scanline {
  0%   { top: -2px; }
  100% { top: 100%; }
}
@keyframes vc-hex-drift {
  0%   { background-position: 0 0; }
  100% { background-position: 60px 104px; }
}
@keyframes vc-glow-pulse {
  0%, 100% { opacity: 0.4; filter: blur(40px); }
  50%      { opacity: 0.7; filter: blur(50px); }
}
@keyframes vc-core-breathe {
  0%, 100% { transform: scale(1);   opacity: 0.6; }
  50%      { transform: scale(1.3); opacity: 1; }
}

.vc-overlay {
  position: fixed;
  inset: 0;
  background: #030310;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0;
  z-index: 300;
  overflow: hidden;
  font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
}

/* Hex grid background */
.vc-hex-grid {
  position: absolute;
  inset: 0;
  opacity: 0.04;
  background-image:
    linear-gradient(30deg, rgba(0,180,255,0.3) 12%, transparent 12.5%, transparent 87.5%, rgba(0,180,255,0.3) 87.5%),
    linear-gradient(150deg, rgba(0,180,255,0.3) 12%, transparent 12.5%, transparent 87.5%, rgba(0,180,255,0.3) 87.5%),
    linear-gradient(30deg, rgba(0,180,255,0.3) 12%, transparent 12.5%, transparent 87.5%, rgba(0,180,255,0.3) 87.5%),
    linear-gradient(150deg, rgba(0,180,255,0.3) 12%, transparent 12.5%, transparent 87.5%, rgba(0,180,255,0.3) 87.5%),
    linear-gradient(60deg, rgba(0,180,255,0.15) 25%, transparent 25.5%, transparent 75%, rgba(0,180,255,0.15) 75%),
    linear-gradient(60deg, rgba(0,180,255,0.15) 25%, transparent 25.5%, transparent 75%, rgba(0,180,255,0.15) 75%);
  background-size: 60px 104px;
  background-position: 0 0, 0 0, 30px 52px, 30px 52px, 0 0, 30px 52px;
  animation: vc-hex-drift 8s linear infinite;
  pointer-events: none;
}

/* Scanline */
.vc-scanline {
  position: absolute;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, rgba(0,200,255,0.15), transparent);
  animation: vc-scanline 4s linear infinite;
  pointer-events: none;
  z-index: 1;
}

/* Top HUD bar */
.vc-hud-top {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 24px;
  z-index: 10;
  border-bottom: 1px solid rgba(0,180,255,0.08);
}
.vc-hud-left, .vc-hud-right {
  display: flex;
  align-items: center;
  gap: 12px;
}
.vc-dot-live {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #00e5ff;
  box-shadow: 0 0 8px rgba(0,229,255,0.6);
  animation: vc-live-dot 1.4s ease-in-out infinite;
}
.vc-dot-muted { background: #666 !important; box-shadow: none !important; animation: none !important; }
.vc-name {
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 4px;
  color: #00c8ff;
}
.vc-version {
  font-size: 10px;
  color: rgba(0,200,255,0.35);
  letter-spacing: 1px;
}
.vc-timer {
  font-size: 13px;
  font-weight: 500;
  color: rgba(0,200,255,0.5);
  letter-spacing: 2px;
  font-variant-numeric: tabular-nums;
}
.vc-status-badge {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 2px;
  padding: 4px 12px;
  border-radius: 3px;
  border: 1px solid;
}
.vc-badge-idle      { color: rgba(0,200,255,0.6); border-color: rgba(0,200,255,0.2); background: rgba(0,200,255,0.05); }
.vc-badge-listening { color: #00e5ff; border-color: rgba(0,229,255,0.4); background: rgba(0,229,255,0.1); }
.vc-badge-thinking  { color: #ffd740; border-color: rgba(255,215,64,0.3); background: rgba(255,215,64,0.08); }
.vc-badge-speaking  { color: #00ff8c; border-color: rgba(0,255,140,0.3); background: rgba(0,255,140,0.08); }
.vc-badge-muted     { color: #666; border-color: rgba(100,100,100,0.3); background: rgba(100,100,100,0.05); }
.vc-badge-error     { color: #ff5555; border-color: rgba(255,85,85,0.3); background: rgba(255,85,85,0.08); }

/* Central orb */
.vc-orb-wrap {
  position: relative;
  width: 300px;
  height: 300px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24px;
}
.vc-viz-canvas {
  position: absolute;
  inset: -50px;
  width: 400px;
  height: 400px;
  z-index: 5;
  pointer-events: none;
}
.vc-orb {
  position: relative;
  width: 180px;
  height: 180px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Rings */
.vc-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 1px solid rgba(0, 200, 255, 0.15);
  transition: border-color 0.5s, box-shadow 0.5s;
}
.vc-ring-1 { animation: vc-breathe 3s ease-in-out infinite; }
.vc-ring-2 { inset: -20px; border-color: rgba(0,200,255,0.08); animation: vc-breathe 3s ease-in-out infinite 0.4s; }
.vc-ring-3 { inset: -40px; border-color: rgba(0,200,255,0.04); animation: vc-breathe 3s ease-in-out infinite 0.8s; }

/* Orb core */
.vc-orb-core {
  position: relative;
  z-index: 6;
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #0a1e3d 0%, #030310 70%);
  border: 1.5px solid rgba(0, 200, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  transition: box-shadow 0.4s ease, border-color 0.4s ease;
}
.vc-core-inner {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0,200,255,0.6) 0%, rgba(0,200,255,0) 70%);
  animation: vc-core-breathe 2.5s ease-in-out infinite;
  transition: transform 0.1s ease;
}

/* ── Per-state orb effects ── */
.vc-orb-idle .vc-orb-core { box-shadow: 0 0 30px rgba(0,200,255,0.1), inset 0 0 20px rgba(0,200,255,0.05); }
.vc-orb-idle .vc-core-inner { background: radial-gradient(circle, rgba(0,200,255,0.4) 0%, transparent 70%); }

.vc-orb-listening .vc-orb-core {
  box-shadow: 0 0 60px rgba(0,229,255,0.35), inset 0 0 30px rgba(0,229,255,0.1);
  border-color: rgba(0,229,255,0.6);
}
.vc-orb-listening .vc-core-inner { background: radial-gradient(circle, rgba(0,229,255,0.9) 0%, transparent 70%); }
.vc-orb-listening .vc-ring-1 { border-color: rgba(0,229,255,0.4); animation: vc-ripple 2s ease-out infinite; }
.vc-orb-listening .vc-ring-2 { border-color: rgba(0,229,255,0.2); animation: vc-ripple 2s ease-out infinite 0.5s; }
.vc-orb-listening .vc-ring-3 { border-color: rgba(0,229,255,0.1); animation: vc-ripple 2s ease-out infinite 1s; }

.vc-orb-thinking .vc-orb-core {
  border-color: rgba(255,215,64,0.5);
  box-shadow: 0 0 50px rgba(255,215,64,0.2), inset 0 0 20px rgba(255,215,64,0.05);
  animation: vc-spin-slow 3s linear infinite;
}
.vc-orb-thinking .vc-core-inner { background: radial-gradient(circle, rgba(255,215,64,0.7) 0%, transparent 70%); }
.vc-orb-thinking .vc-ring-1 { border-color: rgba(255,215,64,0.2); }
.vc-orb-thinking .vc-ring-2 { border-color: rgba(255,215,64,0.1); }

.vc-orb-speaking .vc-orb-core {
  border-color: rgba(0,255,140,0.5);
  box-shadow: 0 0 60px rgba(0,255,140,0.25), inset 0 0 30px rgba(0,255,140,0.08);
}
.vc-orb-speaking .vc-core-inner { background: radial-gradient(circle, rgba(0,255,140,0.9) 0%, transparent 70%); animation: vc-core-breathe 1s ease-in-out infinite; }
.vc-orb-speaking .vc-ring-1 { border-color: rgba(0,255,140,0.35); animation: vc-ripple 1.2s ease-out infinite; }
.vc-orb-speaking .vc-ring-2 { border-color: rgba(0,255,140,0.18); animation: vc-ripple 1.2s ease-out infinite 0.3s; }
.vc-orb-speaking .vc-ring-3 { border-color: rgba(0,255,140,0.08); animation: vc-ripple 1.2s ease-out infinite 0.6s; }

.vc-orb-muted .vc-orb-core {
  border-color: rgba(100,100,120,0.3);
  box-shadow: none;
  opacity: 0.4;
}
.vc-orb-muted .vc-core-inner { background: radial-gradient(circle, rgba(100,100,120,0.3) 0%, transparent 70%); animation: none; }
.vc-orb-muted .vc-ring { border-color: rgba(100,100,120,0.1); animation: none; }

.vc-orb-error .vc-orb-core {
  border-color: rgba(255,85,85,0.5);
  box-shadow: 0 0 40px rgba(255,85,85,0.2);
}
.vc-orb-error .vc-core-inner { background: radial-gradient(circle, rgba(255,85,85,0.7) 0%, transparent 70%); animation: none; }

/* Wave bar visualizer */
.vc-wave-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 3px;
  height: 40px;
  margin-bottom: 16px;
}
.vc-wave-line {
  width: 2px;
  background: linear-gradient(to top, rgba(0,200,255,0.1), rgba(0,200,255,0.5));
  border-radius: 2px;
  transition: height 0.08s ease;
  min-height: 3px;
}

/* Status / transcript text */
.vc-status-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  min-height: 60px;
  margin-bottom: 40px;
  max-width: 500px;
  padding: 0 20px;
}
.vc-transcript-text {
  font-size: 13px;
  color: rgba(0,200,255,0.7);
  text-align: center;
  line-height: 1.6;
  letter-spacing: 0.3px;
}
.vc-response-text {
  font-size: 14px;
  color: rgba(0,255,140,0.8);
  text-align: center;
  line-height: 1.6;
  letter-spacing: 0.3px;
}
.vc-transcript-label {
  display: inline-block;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 2px;
  padding: 2px 8px;
  border-radius: 2px;
  margin-right: 8px;
  vertical-align: middle;
  background: rgba(0,200,255,0.1);
  border: 1px solid rgba(0,200,255,0.2);
  color: rgba(0,200,255,0.6);
}
.vc-response-text .vc-transcript-label {
  background: rgba(0,255,140,0.08);
  border-color: rgba(0,255,140,0.2);
  color: rgba(0,255,140,0.6);
}
.vc-error-text {
  font-size: 13px;
  color: #ff5555;
  max-width: 400px;
  text-align: center;
  line-height: 1.5;
}

/* Controls */
.vc-controls {
  display: flex;
  align-items: center;
  gap: 24px;
}

.vc-mute-btn {
  width: 56px;
  height: 56px;
  border-radius: 12px;
  background: rgba(0,200,255,0.04);
  border: 1px solid rgba(0,200,255,0.15);
  cursor: pointer;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  color: rgba(0,200,255,0.6);
  transition: all 0.2s ease;
}
.vc-mute-btn:hover { background: rgba(0,200,255,0.1); border-color: rgba(0,200,255,0.3); color: #00e5ff; transform: scale(1.05); }
.vc-mute-active {
  background: rgba(255,85,85,0.08) !important;
  border-color: rgba(255,85,85,0.3) !important;
  color: #ff5555 !important;
}

.vc-end-btn {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff3355, #cc2244);
  border: 1px solid rgba(255,51,85,0.4);
  cursor: pointer;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  color: #fff;
  transition: all 0.2s ease;
  box-shadow: 0 0 30px rgba(255,51,85,0.25);
}
.vc-end-btn:hover {
  transform: scale(1.08);
  box-shadow: 0 0 50px rgba(255,51,85,0.4);
}
.vc-btn-label {
  font-size: 8px;
  font-weight: 600;
  letter-spacing: 1.5px;
  margin-top: 2px;
}

/* Bottom HUD */
.vc-hud-bottom {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 24px;
  font-size: 9px;
  letter-spacing: 2px;
  color: rgba(0,200,255,0.2);
  border-top: 1px solid rgba(0,180,255,0.06);
  z-index: 10;
}

.sidebar-voice-btn {
  width: 100%;
  background: transparent;
  border: 1px solid var(--border);
  color: var(--text-secondary);
  border-radius: var(--radius-sm);
  padding: 8px;
  font-size: 12px;
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
  margin-bottom: 6px;
}
.sidebar-voice-btn:hover { background: var(--bg-hover); color: var(--accent); }

/* ── Memories Panel ──────────────────────────────── */

.memories-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 24px 30px;
  overflow-y: auto;
  max-width: 700px;
  margin: 0 auto;
  width: 100%;
}
.memories-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
}
.memories-header h2 {
  font-size: 22px;
  font-weight: 700;
  color: var(--accent);
}
.memories-close {
  background: none;
  border: 1px solid var(--border);
  color: var(--text-secondary);
  width: 32px;
  height: 32px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s, color 0.15s;
}
.memories-close:hover { background: var(--bg-hover); color: var(--text); }

.memories-loading {
  color: var(--text-muted);
  text-align: center;
  padding: 40px;
  font-size: 14px;
}

.memories-section {
  margin-bottom: 20px;
}
.memories-section h3 {
  font-size: 13px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text-secondary);
  margin-bottom: 10px;
}

/* User profile facts */
.memories-facts {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 12px 16px;
}
.memory-fact {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.03);
}
.memory-fact:last-child { border-bottom: none; }
.memory-fact-key {
  font-size: 13px;
  color: var(--text-secondary);
  text-transform: capitalize;
}
.memory-fact-value {
  font-size: 13px;
  color: var(--accent);
  font-family: var(--font-mono);
  max-width: 60%;
  text-align: right;
  word-break: break-word;
}

/* Search bar */
.memories-search {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
}
.memories-search-input {
  flex: 1;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text);
  padding: 8px 12px;
  font-size: 13px;
  font-family: var(--font);
  outline: none;
  transition: border-color 0.2s;
}
.memories-search-input:focus { border-color: var(--accent); }
.memories-search-input::placeholder { color: var(--text-muted); }
.memories-search-btn {
  background: var(--accent-dim);
  border: 1px solid rgba(0, 212, 255, 0.25);
  color: var(--accent);
  border-radius: var(--radius-sm);
  padding: 7px 12px;
  font-size: 14px;
  cursor: pointer;
  transition: background 0.15s;
}
.memories-search-btn:hover { background: rgba(0, 212, 255, 0.25); }
.memories-search-clear {
  background: none;
  border: none;
  color: var(--text-muted);
  font-size: 12px;
  cursor: pointer;
  text-decoration: underline;
}
.memories-search-clear:hover { color: var(--text-secondary); }

.memories-empty {
  color: var(--text-muted);
  font-size: 13px;
  text-align: center;
  padding: 24px;
  background: var(--bg-card);
  border-radius: var(--radius);
  border: 1px solid var(--border);
}

/* Memory items list */
.memories-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.memory-item {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 12px 16px;
  transition: border-color 0.15s;
}
.memory-item:hover { border-color: rgba(0, 212, 255, 0.2); }
.memory-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4px;
}
.memory-item-category {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.4px;
  color: var(--accent);
  background: var(--accent-dim);
  padding: 1px 6px;
  border-radius: 3px;
  font-weight: 600;
}
.memory-item-importance {
  font-size: 11px;
  color: var(--warning);
  letter-spacing: -1px;
}
.memory-item-key {
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 2px;
}
.memory-item-value {
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.5;
  word-break: break-word;
}
.memory-item-meta {
  display: flex;
  gap: 12px;
  margin-top: 6px;
  font-size: 11px;
  color: var(--text-muted);
}

/* Sidebar memories button */
.sidebar-memories-btn {
  width: 100%;
  background: transparent;
  border: 1px solid var(--border);
  color: var(--text-secondary);
  border-radius: var(--radius-sm);
  padding: 8px;
  font-size: 12px;
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
  margin-bottom: 6px;
}
.sidebar-memories-btn:hover { background: var(--bg-hover); color: var(--text); }

/* ── Responsive ──────────────────────────────────── */

/* Topbar — visible on all sizes */
.topbar {
  display: flex;
  align-items: center;
  padding: 6px 20px;
  background: var(--bg-sidebar);
  border-bottom: 1px solid var(--border);
  gap: 8px;
}
.topbar-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-secondary);
}
.hamburger {
  display: none;
  background: none;
  border: none;
  color: var(--text);
  font-size: 22px;
  cursor: pointer;
  padding: 4px 8px;
  border-radius: var(--radius-sm);
}
.hamburger:hover { background: var(--bg-hover); }

/* Mobile sidebar overlay */
.sidebar-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 90;
}

@media (max-width: 768px) {
  .hamburger { display: block; }
  .sidebar-overlay { display: block; }

  .sidebar {
    position: fixed;
    left: 0;
    top: 0;
    bottom: 0;
    width: 280px;
    min-width: 280px;
    z-index: 100;
    transform: translateX(-100%);
    transition: transform 0.25s ease;
    box-shadow: 4px 0 20px rgba(0, 0, 0, 0.5);
  }
  .sidebar.sidebar-mobile-open {
    transform: translateX(0);
  }

  .main { width: 100%; }

  .message-row { max-width: 100%; padding: 6px 12px; }
  .message-bubble { max-width: 92%; font-size: 14px; padding: 10px 14px; }

  .input-area { padding: 8px 10px; gap: 6px; }
  .input-area textarea { font-size: 16px; /* prevents iOS zoom */ }

  /* Dashboard mobile fixes */
  .dashboard { padding: 12px; }
  .dash-cards { grid-template-columns: repeat(2, 1fr); gap: 8px; }
  .dash-card { padding: 10px; }
  .health-grid { grid-template-columns: 1fr; }
  .kv-grid { grid-template-columns: 1fr 1fr; font-size: 12px; }
  .feed-item { font-size: 12px; }

  /* Settings / panels */
  .settings-panel, .memories-panel { padding: 16px; }
}

/* Small phone */
@media (max-width: 420px) {
  .topbar { padding: 6px 10px; }
  .dash-cards { grid-template-columns: 1fr; }
  .sidebar-footer button { font-size: 11px; padding: 6px; }
}

/* ── Symbol System & Glow Effects ────────────────── */

/* Keyframes */
@keyframes pulse-dot {
  0%, 100% { opacity: 1; text-shadow: 0 0 4px var(--success); }
  50%       { opacity: 0.5; text-shadow: 0 0 10px var(--success); }
}
@keyframes spin-slow {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* Service dots */
.svc-dot {
  font-size: 11px;
  font-weight: 700;
  color: var(--success);
  animation: pulse-dot 2.5s ease-in-out infinite;
}
.service-item.svc-down .svc-dot {
  color: var(--danger);
  animation: none;
  text-shadow: 0 0 6px rgba(243, 139, 168, 0.6);
}

/* Health card icons */
.h-icon { font-size: 16px; font-weight: 700; }
.h-ok .h-icon {
  color: var(--accent);
  text-shadow: 0 0 8px rgba(0, 212, 255, 0.7);
}
.h-down .h-icon {
  color: var(--danger);
  text-shadow: 0 0 8px rgba(243, 139, 168, 0.6);
}

/* Stat card icons */
.card-icon { font-size: 22px; color: var(--accent); line-height: 1; }
.card-ok .card-icon {
  color: var(--accent);
  text-shadow: 0 0 12px rgba(0, 212, 255, 0.8);
}
.card-warn .card-icon {
  color: var(--warning);
  text-shadow: 0 0 10px rgba(249, 226, 175, 0.7);
}

/* Guardian badges */
.g-badge { font-size: 13px; font-weight: 700; }
.g-badge:not(.blocked) {
  color: var(--success);
  animation: pulse-dot 2.5s ease-in-out infinite;
}
.g-badge.blocked {
  color: var(--danger);
  text-shadow: 0 0 6px rgba(243, 139, 168, 0.6);
}

/* Recovery indicators */
.r-ok span:nth-child(2)  { color: var(--success); }
.r-fail span:nth-child(2) { color: var(--danger); }

/* Category icons in activity feed */
.cat-icon { font-size: 11px; }
.feed-cat { display: inline-flex; align-items: center; gap: 3px; font-size: 10px; }
.cat-system   .cat-icon { color: var(--accent); }
.cat-security .cat-icon { color: #c9b1ff; }
.cat-error    .cat-icon { color: var(--danger); }
.cat-success  .cat-icon { color: var(--success); }
.cat-action   .cat-icon { color: var(--text-secondary); }

/* Glow classes — apply to any element */
.glow-cyan   { text-shadow: 0 0 10px rgba(0, 212, 255, 0.8); color: var(--accent); }
.glow-purple { text-shadow: 0 0 10px rgba(180, 130, 255, 0.8); color: #c9b1ff; }
.glow-amber  { text-shadow: 0 0 10px rgba(249, 226, 175, 0.8); color: var(--warning); }
.glow-red    { text-shadow: 0 0 10px rgba(243, 139, 168, 0.8); color: var(--danger); }

/* Severity indicators in alerts */
.alert-severity { font-weight: 700; }

/* Mood indicator */
.mood-indicator { font-size: 14px; color: var(--accent); }

/* Tab labels */
.dash-tab { letter-spacing: 0.5px; }

/* ── Alert Banner ────────────────────────────────── */

.alert-banner {
  background: var(--bg-card);
  border-bottom: 1px solid var(--border);
  padding: 8px 16px;
  max-height: 220px;
  overflow-y: auto;
}
.alert-banner-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6px;
}
.alert-banner-count {
  font-size: 12px;
  font-weight: 600;
  color: var(--warning);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.alert-dismiss-all {
  background: none;
  border: none;
  color: var(--text-muted);
  font-size: 11px;
  cursor: pointer;
  text-decoration: underline;
}
.alert-dismiss-all:hover { color: var(--text-secondary); }

.alert-banner-list {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.alert-item {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  padding: 7px 10px;
  border-radius: var(--radius-sm);
  font-size: 12px;
  line-height: 1.4;
}
.alert-critical { background: rgba(243, 139, 168, 0.08); border: 1px solid rgba(243, 139, 168, 0.2); }
.alert-warning  { background: rgba(249, 226, 175, 0.06); border: 1px solid rgba(249, 226, 175, 0.15); }
.alert-info     { background: rgba(0, 212, 255, 0.05); border: 1px solid rgba(0, 212, 255, 0.12); }

.alert-icon { font-size: 12px; flex-shrink: 0; margin-top: 1px; }
.alert-critical .alert-icon { color: var(--danger); }
.alert-warning .alert-icon  { color: var(--warning); }
.alert-info .alert-icon     { color: var(--accent); }
.alert-body { flex: 1; min-width: 0; }
.alert-title {
  font-weight: 600;
  color: var(--text);
  display: flex;
  align-items: center;
  gap: 6px;
}
.alert-category {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.3px;
  color: var(--text-muted);
  background: rgba(255, 255, 255, 0.04);
  padding: 1px 5px;
  border-radius: 3px;
}
.alert-message {
  color: var(--text-secondary);
  margin-top: 2px;
}
.alert-dismiss {
  background: none;
  border: none;
  color: var(--text-muted);
  cursor: pointer;
  font-size: 13px;
  padding: 0 4px;
  flex-shrink: 0;
}
.alert-dismiss:hover { color: var(--text); }

/* ── Mood Bars (Settings) ────────────────────────── */

.mood-bar-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 4px 0;
}
.mood-bar-label {
  width: 80px;
  font-size: 12px;
  color: var(--text-secondary);
  text-transform: capitalize;
}
.mood-bar-track {
  flex: 1;
  height: 6px;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 3px;
  overflow: hidden;
}
.mood-bar-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.5s ease;
}
.mood-bar-value {
  width: 36px;
  font-size: 11px;
  color: var(--text-muted);
  text-align: right;
  font-family: var(--font-mono);
}

/* ── Alert badge on sidebar settings button ──────── */

.sidebar-settings-btn {
  position: relative;
}
.alert-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  background: var(--danger);
  color: #0a0a1a;
  font-size: 10px;
  font-weight: 700;
  min-width: 16px;
  height: 16px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4px;
}


/* ═══════════════════════════════════════════════════════
   Activity Dashboard
   ═══════════════════════════════════════════════════════ */

.sidebar-dashboard-btn {
  width: 100%;
  padding: 8px 12px;
  background: var(--accent-dim);
  color: var(--accent);
  border: 1px solid rgba(0, 212, 255, 0.25);
  border-radius: var(--radius-sm);
  cursor: pointer;
  font-size: 13px;
  margin-bottom: 6px;
  transition: background 0.15s;
}
.sidebar-dashboard-btn:hover { background: rgba(0, 212, 255, 0.25); }

.dashboard {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--bg);
}

.dash-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
  background: var(--bg-sidebar);
  border-bottom: 1px solid var(--border);
}
.dash-header h2 {
  font-size: 16px;
  font-weight: 700;
  color: var(--accent);
}
.dash-close {
  background: none;
  border: none;
  color: var(--text-muted);
  font-size: 18px;
  cursor: pointer;
  padding: 4px 8px;
  border-radius: var(--radius-sm);
}
.dash-close:hover { background: var(--bg-hover); color: var(--text); }

.dash-tabs {
  display: flex;
  gap: 2px;
  padding: 8px 16px;
  background: var(--bg-sidebar);
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
}
.dash-tab {
  padding: 6px 14px;
  background: transparent;
  color: var(--text-secondary);
  border: none;
  border-radius: var(--radius-sm);
  cursor: pointer;
  font-size: 12px;
  white-space: nowrap;
  transition: all 0.15s;
}
.dash-tab:hover { background: var(--bg-hover); color: var(--text); }
.dash-tab.active {
  background: var(--accent-dim);
  color: var(--accent);
  font-weight: 600;
}

.dash-body {
  flex: 1;
  overflow-y: auto;
  padding: 16px 20px;
}

/* Cards row */
.dash-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
  gap: 10px;
  margin-bottom: 18px;
}
.dash-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 14px;
  text-align: center;
}
.dash-card.card-ok { border-color: rgba(166, 227, 161, 0.3); }
.dash-card.card-warn { border-color: rgba(243, 139, 168, 0.4); }
.card-icon { font-size: 22px; margin-bottom: 4px; }
.card-label { font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
.card-value { font-size: 16px; font-weight: 700; color: var(--text); margin-top: 2px; }

/* Sections */
.dash-section {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 14px;
  margin-bottom: 14px;
}
.dash-section h3 {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 10px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.dash-section h4 {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 6px;
}

/* Service grid */
.service-grid { display: flex; flex-direction: column; gap: 6px; }
.service-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 8px;
  background: var(--bg);
  border-radius: var(--radius-sm);
  font-size: 13px;
}
.service-item.svc-down { background: rgba(243, 139, 168, 0.08); }
.svc-name { font-weight: 600; color: var(--text); min-width: 80px; }
.svc-msg { color: var(--text-secondary); flex: 1; font-size: 12px; }
.svc-latency { color: var(--text-muted); font-size: 11px; font-family: var(--font-mono); }

/* Feed list */
.feed-list { display: flex; flex-direction: column; gap: 4px; }
.feed-list.scrollable { max-height: 400px; overflow-y: auto; }
.feed-item {
  display: flex;
  align-items: baseline;
  gap: 8px;
  padding: 5px 8px;
  background: var(--bg);
  border-radius: var(--radius-sm);
  font-size: 12px;
  border-left: 3px solid transparent;
}
.feed-item.cat-decision { border-left-color: var(--accent); }
.feed-item.cat-action { border-left-color: var(--success); }
.feed-item.cat-process { border-left-color: var(--warning); }
.feed-item.cat-task { border-left-color: #cba6f7; }
.feed-item.cat-system { border-left-color: var(--text-muted); }
.feed-item.g-block { border-left-color: var(--danger); background: rgba(243,139,168,0.05); }
.feed-item.g-allow { border-left-color: var(--success); }
.feed-item.r-ok { border-left-color: var(--success); }
.feed-item.r-fail { border-left-color: var(--danger); }
.feed-time { color: var(--text-muted); font-family: var(--font-mono); font-size: 11px; min-width: 70px; }
.feed-cat {
  background: var(--bg-card);
  color: var(--text-secondary);
  padding: 1px 6px;
  border-radius: 3px;
  font-size: 10px;
  text-transform: uppercase;
  font-weight: 600;
}
.feed-summary { color: var(--text); flex: 1; }
.feed-reasoning {
  width: 100%;
  margin-top: 4px;
  padding: 4px 8px;
  background: var(--bg-card);
  border-radius: var(--radius-sm);
  color: var(--text-secondary);
  font-size: 11px;
  font-style: italic;
}
.feed-empty { padding: 20px; text-align: center; color: var(--text-muted); font-size: 13px; }
.feed-msg { color: var(--text-muted); font-size: 11px; }

/* Health grid */
.health-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 10px;
}
.health-card {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 12px;
}
.health-card.h-ok { border-color: rgba(166, 227, 161, 0.25); }
.health-card.h-down { border-color: rgba(243, 139, 168, 0.35); background: rgba(243,139,168,0.05); }
.h-icon { font-size: 20px; margin-bottom: 4px; }
.h-name { font-weight: 600; font-size: 14px; color: var(--text); }
.h-msg { color: var(--text-secondary); font-size: 12px; margin: 4px 0; }
.h-meta { display: flex; gap: 12px; color: var(--text-muted); font-size: 11px; }

/* KV grid for status sections */
.kv-grid {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 6px 14px;
  font-size: 13px;
}
.kv-grid > span:nth-child(odd) { color: var(--text-muted); }
.kv-grid > span:nth-child(even) { color: var(--text); font-weight: 500; }

/* Stats */
.stat-grid { display: flex; gap: 10px; flex-wrap: wrap; }
.stat-item {
  background: var(--bg);
  padding: 8px 14px;
  border-radius: var(--radius-sm);
  display: flex;
  gap: 8px;
  align-items: center;
}
.stat-cat { color: var(--text-secondary); font-size: 12px; text-transform: uppercase; }
.stat-count { font-size: 16px; font-weight: 700; color: var(--accent); }

/* Scheduler items */
.sched-item {
  padding: 10px;
  background: var(--bg);
  border-radius: var(--radius-sm);
  margin-bottom: 6px;
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}
.sched-name { font-weight: 600; color: var(--text); flex: 1; }
.sched-meta { display: flex; gap: 10px; font-size: 11px; color: var(--text-secondary); }
.sched-action {
  background: var(--accent-dim);
  color: var(--accent);
  padding: 1px 6px;
  border-radius: 3px;
  font-size: 10px;
  text-transform: uppercase;
}
.sched-repeat { color: var(--warning); }

/* Failure items */
.failure-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 10px;
  background: rgba(243, 139, 168, 0.08);
  border-radius: var(--radius-sm);
  margin-bottom: 4px;
  font-size: 13px;
}
.failure-count { color: var(--danger); font-weight: 600; }

/* Guardian */
.g-badge {
  font-size: 14px;
}
.g-path {
  color: var(--text-muted);
  font-size: 10px;
  font-family: var(--font-mono);
  max-width: 200px;
  overflow: hidden;
  text-overflow: ellipsis;
}

.text-danger { color: var(--danger) !important; }

/* Buttons */
.dash-btn {
  padding: 8px 16px;
  background: var(--accent-dim);
  color: var(--accent);
  border: 1px solid rgba(0, 212, 255, 0.3);
  border-radius: var(--radius-sm);
  cursor: pointer;
  font-size: 13px;
  margin-top: 10px;
  transition: background 0.15s;
}
.dash-btn:hover { background: rgba(0, 212, 255, 0.25); }
.dash-btn-sm {
  padding: 3px 10px;
  background: var(--bg-card);
  color: var(--text-secondary);
  border: 1px solid var(--border);
  border-radius: 4px;
  cursor: pointer;
  font-size: 11px;
  transition: all 0.15s;
}
.dash-btn-sm:hover { background: var(--bg-hover); color: var(--text); }
.dash-btn-sm.danger:hover { background: rgba(243, 139, 168, 0.15); color: var(--danger); }

/* Time section */
.time-section {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 14px;
}
.time-label { color: var(--text-muted); font-size: 12px; }
.time-value { color: var(--accent); font-family: var(--font-mono); font-size: 13px; font-weight: 600; }

/* ═══════════════════════════════════════════════════════
   Feedback Buttons (on MessageBubble)
   ═══════════════════════════════════════════════════════ */
.feedback-buttons {
  display: flex;
  gap: 4px;
  margin-top: 6px;
  opacity: 0;
  transition: opacity 0.15s;
}
.message-row.assistant:hover .feedback-buttons { opacity: 1; }
.fb-btn {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--text-muted);
  font-size: 11px;
  padding: 2px 8px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: all 0.15s;
}
.fb-btn:hover { border-color: var(--accent); color: var(--accent); }
.fb-btn.active.fb-up { border-color: var(--success); color: var(--success); opacity: 1; }
.fb-btn.active.fb-down { border-color: var(--danger); color: var(--danger); opacity: 1; }
.fb-btn:disabled { cursor: default; }

/* ═══════════════════════════════════════════════════════
   Learning Panel
   ═══════════════════════════════════════════════════════ */
.sidebar-learning-btn {
  width: 100%;
  padding: 8px 12px;
  background: transparent;
  border: none;
  color: var(--text-secondary);
  font-size: 13px;
  text-align: left;
  cursor: pointer;
  border-radius: var(--radius-sm);
  transition: all 0.15s;
}
.sidebar-learning-btn:hover { background: var(--bg-hover); color: var(--accent); }

.learn-actions { margin: 16px 0; display: flex; flex-wrap: wrap; gap: 8px; }
.learn-btn {
  padding: 8px 16px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  color: var(--text);
  border-radius: var(--radius-sm);
  cursor: pointer;
  font-size: 13px;
  transition: all 0.15s;
}
.learn-btn:hover { border-color: var(--accent); color: var(--accent); }
.learn-btn:disabled { opacity: 0.4; cursor: default; }
.learn-btn-sm {
  padding: 4px 10px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  color: var(--text-secondary);
  border-radius: var(--radius-sm);
  cursor: pointer;
  font-size: 12px;
  transition: all 0.15s;
}
.learn-btn-sm:hover { border-color: var(--accent); color: var(--accent); }
.btn-approve { border-color: var(--success); color: var(--success); }
.btn-approve:hover { background: rgba(166, 227, 161, 0.1); }
.btn-reject { border-color: var(--danger); color: var(--danger); }
.btn-reject:hover { background: rgba(243, 139, 168, 0.1); }
.btn-edit { border-color: var(--warning); color: var(--warning); }
.btn-edit:hover { background: rgba(249, 226, 175, 0.1); }

.learn-empty { color: var(--text-muted); font-size: 13px; padding: 12px 0; }
.learn-info { margin-top: 16px; }
.learn-info h3 { color: var(--text); font-size: 14px; margin-bottom: 8px; }
.learn-info p { color: var(--text-secondary); font-size: 13px; margin-bottom: 6px; line-height: 1.5; }

/* Training Pairs */
.train-pair {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 12px;
  margin-bottom: 10px;
}
.train-pair.approved { border-left: 3px solid var(--success); }
.train-label { color: var(--text-muted); font-size: 11px; text-transform: uppercase; margin-right: 8px; }
.train-text { color: var(--text); font-size: 13px; line-height: 1.4; }
.train-user, .train-nova { margin-bottom: 6px; }
.train-actions { display: flex; gap: 6px; margin-top: 8px; }
.train-edit textarea {
  width: 100%;
  background: var(--bg-input);
  border: 1px solid var(--border);
  color: var(--text);
  border-radius: var(--radius-sm);
  padding: 8px;
  font-size: 13px;
  font-family: var(--font);
  resize: vertical;
  margin-bottom: 6px;
}

/* Patterns */
.pattern-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 12px;
  margin-bottom: 8px;
}
.pattern-meta { display: flex; justify-content: space-between; margin-bottom: 6px; }
.pattern-cat {
  font-size: 11px;
  text-transform: uppercase;
  color: var(--accent);
  background: var(--accent-dim);
  padding: 2px 8px;
  border-radius: 3px;
}
.pattern-conf { font-size: 12px; color: var(--text-muted); }
.pattern-text { color: var(--text); font-size: 13px; line-height: 1.4; margin-bottom: 8px; }

/* Feedback Log */
.feedback-row {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
}
.fb-signal { font-size: 16px; min-width: 24px; text-align: center; }
.fb-signal.fb-positive { color: var(--success); }
.fb-signal.fb-negative { color: var(--danger); }
.fb-signal.fb-correction { color: var(--warning); }
.fb-detail { flex: 1; }
.fb-cat { font-size: 11px; color: var(--text-muted); }
.fb-msg { font-size: 13px; color: var(--text-secondary); margin-top: 2px; }
.fb-correction { font-size: 13px; color: var(--warning); margin-top: 2px; }
