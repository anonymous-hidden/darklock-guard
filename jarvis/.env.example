# JARVIS-Lite — Environment
# Ollama is local — no AI API key needed.
# Make sure `ollama serve` is running before starting.

# Optional: API authentication token for remote access
# JARVIS_API_KEY=generate-a-secure-key-here

# Govee Smart Lights (get from Govee Home app → Profile → Settings → Apply for API Key)
GOVEE_API_KEY=paste-your-key-here

# OpenWeather API (free tier: https://openweathermap.org/api)
OPENWEATHER_API_KEY=paste-your-key-here

# Google OAuth 2.0
# No API key needed here — download OAuth credentials JSON from:
#   Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Desktop app)
# Save as: jarvis/data/google_credentials.json
# Then run: cd jarvis && python -m integrations.google_auth
