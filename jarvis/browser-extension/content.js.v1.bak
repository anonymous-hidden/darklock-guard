/**
 * Nova Browser Bridge — Content Script
 * ======================================
 * Injected into every page. Handles DOM reading, typing, clicking,
 * form filling, and other page-level interactions.
 */

(() => {
  // On re-injection, update the handler function but DON'T add another listener.
  // The single listener always delegates to window.__novaBridgeHandler (latest code).
  window.__novaBridgeHandler = handleAction;

  if (!window.__novaBridgeInjected) {
    window.__novaBridgeInjected = true;
    chrome.runtime.onMessage.addListener((msg, sender, sendResponse) => {
      // Always call the LATEST handler (updated on re-injection)
      window.__novaBridgeHandler(msg.action, msg.args || {})
        .then(sendResponse)
        .catch((err) => sendResponse({ success: false, error: err.message }));
      return true; // async response
    });
  }

  // ── Action router ────────────────────────────────

  async function handleAction(action, args) {
    switch (action) {
      case "get_page_content":
        return getPageContent(args);
      case "get_page_text":
        return getPageText(args);
      case "get_selected_text":
        return getSelectedText();
      case "get_input_values":
        return getInputValues();
      case "type_text":
        return typeText(args);
      case "click_element":
        return clickElement(args);
      case "scroll_page":
        return scrollPage(args);
      case "fill_form":
        return fillForm(args);
      case "get_links":
        return getLinks(args);
      case "press_key":
        return pressKey(args);
      case "focus_element":
        return focusElement(args);
      case "wait_for_element":
        return waitForElement(args);
      case "go_back":
        history.back();
        return { success: true };
      case "go_forward":
        history.forward();
        return { success: true };
      default:
        return { success: false, error: `Unknown content action: ${action}` };
    }
  }

  // ── Page reading ─────────────────────────────────

  function getPageContent(args) {
    const maxChars = args.max_chars || 15000;

    // ── Google Docs special reader ──
    if (isGoogleDocs()) {
      return getGoogleDocsContent(maxChars);
    }

    // Try to get main content area
    const main = document.querySelector(
      "main, article, [role='main'], .content, #content, .post-content, .entry-content"
    );
    const target = main || document.body;

    // Clone and strip non-content elements
    const clone = target.cloneNode(true);
    clone.querySelectorAll("script, style, noscript, nav, footer, header, .sidebar, .ad, .advertisement, iframe")
      .forEach((el) => el.remove());

    let text = clone.innerText || clone.textContent || "";
    text = text.replace(/\n{3,}/g, "\n\n").trim();

    if (text.length > maxChars) {
      text = text.slice(0, maxChars) + "\n\n... [truncated]";
    }

    // Get headings
    const headings = Array.from(document.querySelectorAll("h1, h2, h3, h4"))
      .slice(0, 20)
      .map((h) => `${h.tagName}: ${(h.innerText || "").trim()}`)
      .filter((h) => h.length > 4);

    // Get forms info
    const forms = document.querySelectorAll("form").length;

    // Get meta description
    const metaDesc = document.querySelector('meta[name="description"]');

    return {
      success: true,
      url: location.href,
      title: document.title,
      text,
      headings,
      forms,
      meta_description: metaDesc ? metaDesc.content : "",
      word_count: text.split(/\s+/).length,
    };
  }

  function getPageText(args) {
    const maxChars = args.max_chars || 10000;
    const main = document.querySelector(
      "main, article, [role='main'], .content, #content"
    );
    const target = main || document.body;
    let text = (target.innerText || target.textContent || "").trim();
    if (text.length > maxChars) {
      text = text.slice(0, maxChars) + "\n... [truncated]";
    }
    return { success: true, text, url: location.href, title: document.title };
  }

  function getSelectedText() {
    const selection = window.getSelection();
    return {
      success: true,
      text: selection ? selection.toString() : "",
    };
  }

  function getInputValues() {
    const inputs = Array.from(document.querySelectorAll(
      "input, textarea, select, [contenteditable='true']"
    ));
    const values = inputs.slice(0, 50).map((el, i) => ({
      index: i,
      tag: el.tagName.toLowerCase(),
      type: el.type || "",
      name: el.name || "",
      id: el.id || "",
      placeholder: el.placeholder || "",
      value: el.value || el.innerText || "",
      label: findLabel(el),
    }));
    return { success: true, inputs: values };
  }

  function getLinks(args) {
    const maxLinks = args.max || 50;
    const links = Array.from(document.querySelectorAll("a[href]"))
      .slice(0, maxLinks)
      .map((a, i) => ({
        index: i,
        text: (a.innerText || "").trim().slice(0, 100),
        href: a.href,
      }))
      .filter((l) => l.text && l.href.startsWith("http"));
    return { success: true, links };
  }

  // ── Google Docs detection & helpers ──────────────

  function isGoogleDocs() {
    return location.hostname === "docs.google.com" &&
           location.pathname.startsWith("/document/");
  }

  /**
   * Extract actual document text from Google Docs' custom DOM.
   * Google Docs renders text in .kix-paragraphrenderer elements, not standard HTML.
   */
  function getGoogleDocsContent(maxChars) {
    const lines = [];

    // Method 1: Read from .kix-paragraphrenderer (main document content)
    const paragraphs = document.querySelectorAll(".kix-paragraphrenderer");
    if (paragraphs.length > 0) {
      for (const p of paragraphs) {
        // Each paragraph has .kix-lineview children with the actual text spans
        const lineViews = p.querySelectorAll(".kix-lineview");
        if (lineViews.length > 0) {
          const paraLines = [];
          for (const lv of lineViews) {
            const text = (lv.innerText || lv.textContent || "").replace(/\u200B/g, "");
            if (text.trim()) paraLines.push(text);
          }
          lines.push(paraLines.join(" "));
        } else {
          // Fallback: read the paragraph directly
          const text = (p.innerText || p.textContent || "").replace(/\u200B/g, "");
          if (text.trim()) lines.push(text);
        }
      }
    }

    // Method 2: Try .kix-page-content-wrapper if paragraphs not found
    if (lines.length === 0) {
      const pages = document.querySelectorAll(".kix-page-content-wrapper");
      for (const page of pages) {
        const text = (page.innerText || page.textContent || "").replace(/\u200B/g, "");
        if (text.trim()) lines.push(text);
      }
    }

    // Method 3: Last resort, try the editor div
    if (lines.length === 0) {
      const editor = document.querySelector(".kix-appview-editor");
      if (editor) {
        const text = (editor.innerText || editor.textContent || "").replace(/\u200B/g, "");
        if (text.trim()) lines.push(text);
      }
    }

    let text = lines.join("\n").replace(/\n{3,}/g, "\n\n").trim();
    if (text.length > maxChars) {
      text = text.slice(0, maxChars) + "\n\n... [truncated]";
    }

    // Also try to read any tables
    const tables = document.querySelectorAll(".kix-tablerenderer");
    const tableData = [];
    for (const table of tables) {
      const rows = table.querySelectorAll(".kix-tablerow");
      for (const row of rows) {
        const cells = row.querySelectorAll(".kix-tablecell");
        const cellTexts = Array.from(cells).map(c => (c.innerText || "").replace(/\u200B/g, "").trim());
        if (cellTexts.some(t => t)) tableData.push("| " + cellTexts.join(" | ") + " |");
      }
    }
    if (tableData.length > 0) {
      text += "\n\n[TABLE]\n" + tableData.join("\n");
    }

    return {
      success: true,
      url: location.href,
      title: document.title,
      text: text || "(Document appears empty — no text found in the editor area)",
      headings: [],
      forms: 0,
      meta_description: "",
      word_count: text.split(/\s+/).length,
      is_google_docs: true,
    };
  }

  /**
   * Get the actual input target for Google Docs.
   * Google Docs captures keystrokes on a hidden iframe textarea.
   */
  function getGoogleDocsTarget() {
    // Method 1: The hidden textarea inside the docs-texteventtarget-iframe
    const iframeEl = document.querySelector("iframe.docs-texteventtarget-iframe");
    if (iframeEl) {
      try {
        const iframeDoc = iframeEl.contentDocument || iframeEl.contentWindow.document;
        const textarea = iframeDoc.querySelector("[contenteditable='true']") || iframeDoc.body;
        if (textarea) return textarea;
      } catch (e) { /* cross-origin or not ready */ }
    }
    // Method 2: The contenteditable div in newer Google Docs
    const ceDiv = document.querySelector(".kix-appview-editor [contenteditable='true']");
    if (ceDiv) return ceDiv;
    // Method 3: Fall back to the editor area
    const editor = document.querySelector(".kix-appview-editor");
    if (editor) return editor;
    return null;
  }

  /**
   * Simulate typing into Google Docs by dispatching keyboard + input events.
   * Google Docs listens for real keyboard events on its hidden textarea.
   */
  async function typeInGoogleDocs(text) {
    // Click the editor to ensure focus
    const editor = document.querySelector(".kix-appview-editor");
    if (editor) {
      editor.dispatchEvent(new MouseEvent("mousedown", { bubbles: true, clientX: 300, clientY: 300 }));
      editor.dispatchEvent(new MouseEvent("mouseup", { bubbles: true, clientX: 300, clientY: 300 }));
      editor.click();
      await sleep(200);
    }

    const target = getGoogleDocsTarget() || document.activeElement;

    for (const char of text) {
      const keyCode = char.charCodeAt(0);
      const key = char;
      const code = char >= "a" && char <= "z" ? `Key${char.toUpperCase()}`
                 : char >= "A" && char <= "Z" ? `Key${char}`
                 : char >= "0" && char <= "9" ? `Digit${char}`
                 : "Unidentified";

      const eventBase = {
        key, code, keyCode, charCode: keyCode, which: keyCode,
        bubbles: true, cancelable: true, composed: true,
      };

      target.dispatchEvent(new KeyboardEvent("keydown", eventBase));
      target.dispatchEvent(new KeyboardEvent("keypress", { ...eventBase, charCode: keyCode }));

      // The InputEvent is what Google Docs actually uses to insert text
      target.dispatchEvent(new InputEvent("beforeinput", {
        inputType: "insertText", data: char, bubbles: true, cancelable: true, composed: true,
      }));
      target.dispatchEvent(new InputEvent("input", {
        inputType: "insertText", data: char, bubbles: true, composed: true,
      }));

      target.dispatchEvent(new KeyboardEvent("keyup", eventBase));

      // Small delay between chars so Google Docs can process each one
      await sleep(10);
    }

    return { success: true, typed: text, chars: text.length, method: "google-docs-events" };
  }

  function pressKeyGoogleDocs(key, modifiers) {
    const target = getGoogleDocsTarget() || document.activeElement || document.body;

    const specialCodes = {
      Enter: "Enter", Tab: "Tab", Escape: "Escape", Backspace: "Backspace",
      Delete: "Delete", ArrowUp: "ArrowUp", ArrowDown: "ArrowDown",
      ArrowLeft: "ArrowLeft", ArrowRight: "ArrowRight", Space: "Space",
    };

    const specialKeyCodes = {
      Enter: 13, Tab: 9, Escape: 27, Backspace: 8, Delete: 46,
      ArrowUp: 38, ArrowDown: 40, ArrowLeft: 37, ArrowRight: 39, Space: 32,
    };

    const code = specialCodes[key] || `Key${key.toUpperCase()}`;
    const keyCode = specialKeyCodes[key] || key.charCodeAt(0);

    const eventInit = {
      key, code, keyCode, charCode: 0, which: keyCode,
      bubbles: true, cancelable: true, composed: true,
      ctrlKey: modifiers?.includes("ctrl") || false,
      shiftKey: modifiers?.includes("shift") || false,
      altKey: modifiers?.includes("alt") || false,
      metaKey: modifiers?.includes("meta") || false,
    };

    target.dispatchEvent(new KeyboardEvent("keydown", eventInit));

    // For Enter, also send an insertLineBreak input event
    if (key === "Enter") {
      target.dispatchEvent(new InputEvent("beforeinput", {
        inputType: "insertParagraph", bubbles: true, cancelable: true, composed: true,
      }));
      target.dispatchEvent(new InputEvent("input", {
        inputType: "insertParagraph", bubbles: true, composed: true,
      }));
    }

    target.dispatchEvent(new KeyboardEvent("keypress", eventInit));
    target.dispatchEvent(new KeyboardEvent("keyup", eventInit));

    return { success: true, key, modifiers: modifiers || [], method: "google-docs-events" };
  }

  // ── Typing & Input ──────────────────────────────

  function typeText(args) {
    const { text, selector, index, clear, delay } = args;

    // Google Docs special path
    if (isGoogleDocs()) {
      return typeInGoogleDocs(text);
    }

    let el = findTargetElement(selector, index);
    if (!el) {
      // Try to find the currently focused element
      el = document.activeElement;
      if (!el || el === document.body) {
        return { success: false, error: "No input element found. Specify a selector or focus an input first." };
      }
    }

    // Focus the element
    el.focus();
    el.click();

    // Clear existing content if requested
    if (clear) {
      if (el.tagName === "INPUT" || el.tagName === "TEXTAREA") {
        el.value = "";
      } else if (el.isContentEditable) {
        el.innerHTML = "";
      }
      el.dispatchEvent(new Event("input", { bubbles: true }));
    }

    // Type character by character for realistic input
    if (delay && delay > 0) {
      return typeWithDelay(el, text, delay);
    }

    // Instant type
    if (el.tagName === "INPUT" || el.tagName === "TEXTAREA") {
      // Use execCommand for better compatibility with React/Angular
      el.focus();
      document.execCommand("insertText", false, text);
      // Fallback if execCommand doesn't work
      if (!el.value.includes(text)) {
        el.value += text;
        el.dispatchEvent(new Event("input", { bubbles: true }));
        el.dispatchEvent(new Event("change", { bubbles: true }));
      }
    } else if (el.isContentEditable) {
      document.execCommand("insertText", false, text);
    }

    return { success: true, typed: text, element: describeElement(el) };
  }

  async function typeWithDelay(el, text, delay) {
    for (const char of text) {
      if (el.tagName === "INPUT" || el.tagName === "TEXTAREA") {
        document.execCommand("insertText", false, char);
      } else if (el.isContentEditable) {
        document.execCommand("insertText", false, char);
      }
      await sleep(delay);
    }
    return { success: true, typed: text, element: describeElement(el) };
  }

  function pressKey(args) {
    const { key, modifiers } = args;

    // Google Docs special path
    if (isGoogleDocs()) {
      return pressKeyGoogleDocs(key, modifiers);
    }

    const target = document.activeElement || document.body;

    const eventInit = {
      key,
      code: `Key${key.toUpperCase()}`,
      bubbles: true,
      cancelable: true,
      ctrlKey: modifiers?.includes("ctrl") || false,
      shiftKey: modifiers?.includes("shift") || false,
      altKey: modifiers?.includes("alt") || false,
      metaKey: modifiers?.includes("meta") || false,
    };

    // Special key codes
    const specialCodes = {
      Enter: "Enter", Tab: "Tab", Escape: "Escape", Backspace: "Backspace",
      Delete: "Delete", ArrowUp: "ArrowUp", ArrowDown: "ArrowDown",
      ArrowLeft: "ArrowLeft", ArrowRight: "ArrowRight", Space: "Space",
    };
    if (specialCodes[key]) {
      eventInit.code = specialCodes[key];
    }

    target.dispatchEvent(new KeyboardEvent("keydown", eventInit));
    target.dispatchEvent(new KeyboardEvent("keypress", eventInit));
    target.dispatchEvent(new KeyboardEvent("keyup", eventInit));

    return { success: true, key, modifiers: modifiers || [] };
  }

  // ── Clicking ─────────────────────────────────────

  function clickElement(args) {
    const { selector, index, text, x, y } = args;

    // Google Docs: clicking .kix-appview-editor needs special handling
    if (isGoogleDocs() && selector && selector.includes("kix-appview-editor")) {
      const editor = document.querySelector(".kix-appview-editor .kix-page");
      const target = editor || document.querySelector(".kix-appview-editor");
      if (target) {
        const rect = target.getBoundingClientRect();
        const cx = rect.left + 100;
        const cy = rect.top + 100;
        target.dispatchEvent(new MouseEvent("mousedown", { bubbles: true, clientX: cx, clientY: cy }));
        target.dispatchEvent(new MouseEvent("mouseup", { bubbles: true, clientX: cx, clientY: cy }));
        target.dispatchEvent(new MouseEvent("click", { bubbles: true, clientX: cx, clientY: cy }));
        return { success: true, clicked: "Google Docs editor area", method: "google-docs-click" };
      }
    }

    let el = null;

    // By coordinates
    if (x !== undefined && y !== undefined) {
      el = document.elementFromPoint(x, y);
    }
    // By text content
    else if (text) {
      el = findElementByText(text);
    }
    // By selector or index
    else {
      el = findTargetElement(selector, index);
    }

    if (!el) {
      return { success: false, error: "Element not found" };
    }

    // Scroll into view
    el.scrollIntoView({ behavior: "smooth", block: "center" });

    // Simulate realistic click
    el.dispatchEvent(new MouseEvent("mouseover", { bubbles: true }));
    el.dispatchEvent(new MouseEvent("mousedown", { bubbles: true }));
    el.dispatchEvent(new MouseEvent("mouseup", { bubbles: true }));
    el.click();

    return { success: true, clicked: describeElement(el) };
  }

  function focusElement(args) {
    const el = findTargetElement(args.selector, args.index);
    if (!el) return { success: false, error: "Element not found" };
    el.focus();
    el.scrollIntoView({ behavior: "smooth", block: "center" });
    return { success: true, focused: describeElement(el) };
  }

  // ── Scrolling ────────────────────────────────────

  function scrollPage(args) {
    const { direction, amount } = args;
    const px = amount || 500;

    switch (direction) {
      case "up":
        window.scrollBy(0, -px);
        break;
      case "down":
        window.scrollBy(0, px);
        break;
      case "top":
        window.scrollTo(0, 0);
        break;
      case "bottom":
        window.scrollTo(0, document.body.scrollHeight);
        break;
      default:
        window.scrollBy(0, px);
    }
    return { success: true, scrollY: window.scrollY };
  }

  // ── Form filling ─────────────────────────────────

  function fillForm(args) {
    const { fields } = args;
    // fields: [{ selector: "...", value: "..." }, ...]
    // or: [{ name: "...", value: "..." }, ...]
    // or: [{ label: "...", value: "..." }, ...]

    const results = [];
    for (const field of fields) {
      let el = null;

      if (field.selector) {
        el = document.querySelector(field.selector);
      } else if (field.name) {
        el = document.querySelector(`[name="${field.name}"]`);
      } else if (field.label) {
        el = findElementByLabel(field.label);
      } else if (field.id) {
        el = document.getElementById(field.id);
      }

      if (!el) {
        results.push({ field: field.selector || field.name || field.label, success: false, error: "Not found" });
        continue;
      }

      el.focus();
      if (el.tagName === "SELECT") {
        el.value = field.value;
        el.dispatchEvent(new Event("change", { bubbles: true }));
      } else {
        el.value = "";
        document.execCommand("insertText", false, field.value);
        if (!el.value) {
          el.value = field.value;
          el.dispatchEvent(new Event("input", { bubbles: true }));
        }
      }
      results.push({ field: field.selector || field.name || field.label, success: true });
    }
    return { success: true, results };
  }

  // ── Wait for element ─────────────────────────────

  function waitForElement(args) {
    const { selector, timeout } = args;
    const maxWait = timeout || 5000;

    return new Promise((resolve) => {
      const existing = document.querySelector(selector);
      if (existing) {
        return resolve({ success: true, found: true });
      }

      const observer = new MutationObserver(() => {
        if (document.querySelector(selector)) {
          observer.disconnect();
          clearTimeout(timer);
          resolve({ success: true, found: true });
        }
      });

      observer.observe(document.body, { childList: true, subtree: true });

      const timer = setTimeout(() => {
        observer.disconnect();
        resolve({ success: true, found: false, timeout: true });
      }, maxWait);
    });
  }

  // ── Helpers ──────────────────────────────────────

  function findTargetElement(selector, index) {
    if (selector) {
      return document.querySelector(selector);
    }
    if (index !== undefined) {
      const inputs = document.querySelectorAll(
        "input, textarea, select, button, a, [contenteditable='true']"
      );
      return inputs[index] || null;
    }
    return null;
  }

  function findElementByText(text) {
    const lower = text.toLowerCase();

    // Check buttons first
    for (const btn of document.querySelectorAll("button, [role='button'], input[type='submit'], input[type='button']")) {
      const btnText = (btn.innerText || btn.value || "").toLowerCase();
      if (btnText.includes(lower)) return btn;
    }

    // Check links
    for (const a of document.querySelectorAll("a")) {
      if ((a.innerText || "").toLowerCase().includes(lower)) return a;
    }

    // Check any visible element with matching text
    const walker = document.createTreeWalker(
      document.body,
      NodeFilter.SHOW_ELEMENT,
      {
        acceptNode: (node) => {
          const t = (node.innerText || "").toLowerCase();
          if (t.includes(lower) && node.offsetParent !== null) {
            return NodeFilter.FILTER_ACCEPT;
          }
          return NodeFilter.FILTER_SKIP;
        },
      }
    );
    // Get the deepest matching element (most specific)
    let best = null;
    let node;
    while ((node = walker.nextNode())) {
      best = node;
    }
    return best;
  }

  function findElementByLabel(labelText) {
    const lower = labelText.toLowerCase();
    for (const label of document.querySelectorAll("label")) {
      if ((label.innerText || "").toLowerCase().includes(lower)) {
        if (label.htmlFor) {
          return document.getElementById(label.htmlFor);
        }
        return label.querySelector("input, textarea, select");
      }
    }
    // Try placeholder match
    for (const input of document.querySelectorAll("input, textarea")) {
      if ((input.placeholder || "").toLowerCase().includes(lower)) {
        return input;
      }
    }
    return null;
  }

  function findLabel(el) {
    // Check for associated label
    if (el.id) {
      const label = document.querySelector(`label[for="${el.id}"]`);
      if (label) return (label.innerText || "").trim();
    }
    // Check parent label
    const parentLabel = el.closest("label");
    if (parentLabel) return (parentLabel.innerText || "").trim();
    // Check aria-label
    if (el.getAttribute("aria-label")) return el.getAttribute("aria-label");
    return "";
  }

  function describeElement(el) {
    const tag = el.tagName.toLowerCase();
    const id = el.id ? `#${el.id}` : "";
    const cls = el.className && typeof el.className === "string"
      ? `.${el.className.split(" ").filter(Boolean).slice(0, 2).join(".")}`
      : "";
    const text = (el.innerText || el.value || "").trim().slice(0, 50);
    return `<${tag}${id}${cls}> "${text}"`;
  }

  function sleep(ms) {
    return new Promise((resolve) => setTimeout(resolve, ms));
  }
})();
