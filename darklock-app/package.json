{
  "name": "darklock-app",
  "version": "1.0.0",
  "description": "DarkLock — Zero-knowledge encrypted desktop messenger",
  "private": true,
  "main": "src/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:server": "node server/index.js & electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "preview": "electron-vite preview",
    "server": "node server/index.js",
    "server:dev": "nodemon server/index.js"
  },
  "dependencies": {
    "libsodium-wrappers": "^0.7.13",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "electron-store": "^8.2.0",
    "zustand": "^4.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "argon2-browser": "^1.18.0",
    "express": "^4.19.2",
    "ws": "^8.17.0",
    "better-sqlite3": "^11.0.0",
    "argon2": "^0.40.1",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.2.0",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "electron": "^30.0.8",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.2.12",
    "tailwindcss": "^3.4.3",
    "postcss": "^8.4.38",
    "autoprefixer": "^10.4.19",
    "nodemon": "^3.1.0"
  },
  "build": {
    "appId": "app.darklock.messenger",
    "productName": "DarkLock",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": ["AppImage", "deb"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "mac": {
      "target": ["dmg"]
    }
  }
}
