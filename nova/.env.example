# NOVA v2 Environment Configuration
# Copy to .env and fill in values for the connectors you want to enable.

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434

# --- GitHub connector ---
GITHUB_TOKEN=
GITHUB_DEFAULT_REPO=

# --- Email connector (SMTP/IMAP) ---
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=

# --- Calendar connector (Google / CalDAV) ---
CALENDAR_PROVIDER=
CALENDAR_TOKEN_PATH=

# --- Weather connector ---
OPENWEATHER_API_KEY=

# --- Web search ---
SEARXNG_URL=https://searx.be
DUCKDUCKGO_ENABLED=true

# --- Discord connector ---
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=

# --- Generic REST API default ---
GENERIC_REST_BASE_URL=
GENERIC_REST_BEARER=

# --- Notes / Cloud storage / Task manager ---
NOTES_PROVIDER_PATH=
CLOUD_STORAGE_PATH=
TASK_MANAGER_URL=

# --- Server monitor ---
SERVER_MONITOR_ENDPOINTS=

# --- Contacts ---
CONTACTS_FILE=
